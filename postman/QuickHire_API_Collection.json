  "item": [
    {
      "name": "Admin",
      "item": [
        {
          "name": "Auth",
          "item": [
            {
              "name": "Register Admin",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/auth/register",
                "body": {
                  "mode": "raw",
                  "raw": "{\"fullName\": \"Admin User\", \"email\": \"admin@quickhire.com\", \"password\": \"Admin123!\", \"role\": \"ADMIN\"}"
                }
              }
            },
            {
              "name": "Login Admin",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const resp = pm.response.json(); if(resp.success) pm.environment.set('quick-hire-admintoken', resp.data.accessToken);"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/auth/login",
                "body": {
                  "mode": "raw",
                  "raw": "{\"email\": \"admin@quickhire.com\", \"password\": \"Admin123!\"}"
                }
              }
            },
            {
              "name": "Verify OTP",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/auth/verify-otp",
                "body": { "mode": "raw", "raw": "{\"sessionId\": \"...\", \"code\": \"123456\"}" }
              }
            },
            {
              "name": "Resend OTP",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/auth/resend-otp",
                "body": { "mode": "raw", "raw": "{\"sessionId\": \"...\"}" }
              }
            },
            {
              "name": "Forgot Password",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/auth/forgot-password",
                "body": { "mode": "raw", "raw": "{\"email\": \"admin@quickhire.com\"}" }
              }
            },
            {
              "name": "Reset Password",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/auth/reset-password",
                "body": {
                  "mode": "raw",
                  "raw": "{\"resetPasswordToken\": \"...\", \"password\": \"NewAdmin123!\"}"
                }
              }
            },
            {
              "name": "Change Password",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/auth/change-password",
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    { "key": "token", "value": "{{quick-hire-admintoken}}", "type": "string" }
                  ]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\"oldPassword\": \"Admin123!\", \"newPassword\": \"Admin1234!\"}"
                }
              }
            }
          ]
