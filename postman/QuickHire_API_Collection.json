{
  "info": {
    "_postman_id": "quick-hire-v2",
    "name": "QuickHire Professional API",
    "description": "Comprehensive API collection for QuickHire job portal, organized by Admin, User, and Company roles.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
