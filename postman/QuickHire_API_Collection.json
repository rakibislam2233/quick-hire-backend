{
  "info": {
    "_postman_id": "quick-hire-ultimate-v5",
    "name": "QuickHire Ultimate API Collection",
    "description": "100% Exhaustive collection. Features Unified Registration, Auto-Activation, and Interview Scheduling. Now includes Form-Data support for file uploads (Images, Logos, Resumes).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Admin",
      "item": [
        {
          "name": "Auth",
          "item": [
            {
              "name": "Register Admin",
              "request": {
                "method": "POST",
                "url": "{{quick-hire-url}}/auth/register",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"fullName\": \"Admin User\",\n  \"email\": \"admin@quickhire.com\",\n  \"password\": \"Admin123!\",\n  \"role\": \"ADMIN\"\n}"
                }
              }
            },
            {
              "name": "Login Admin",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const resp = pm.response.json(); if(resp.success) pm.environment.set('quick-hire-admintoken', resp.data.accessToken);"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "url": "{{quick-hire-url}}/auth/login",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"admin@quickhire.com\",\n  \"password\": \"Admin123!\"\n}"
                }
              }
            }
          ]
        },
        {
          "name": "Dashboard",
          "item": [
            {
              "name": "Get Admin Stats",
              "request": {
                "method": "GET",
                "url": "{{quick-hire-url}}/dashboard/admin",
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    { "key": "token", "value": "{{quick-hire-admintoken}}", "type": "string" }
                  ]
                }
              }
            }
          ]
        }
      ]
    },
    {
      "name": "User (Candidate)",
      "item": [
        {
          "name": "Auth",
          "item": [
            {
              "name": "Register User",
              "request": {
                "method": "POST",
                "url": "{{quick-hire-url}}/auth/register",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"fullName\": \"John Doe\",\n  \"email\": \"john@user.com\",\n  \"password\": \"User1234!\",\n  \"role\": \"USER\"\n}"
                }
              }
            },
            {
              "name": "Login User",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const resp = pm.response.json(); if(resp.success) pm.environment.set('quick-hire-usertoken', resp.data.accessToken);"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "url": "{{quick-hire-url}}/auth/login",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"john@user.com\",\n  \"password\": \"User1234!\"\n}"
                }
              }
            }
          ]
        },
        {
          "name": "Profile",
          "item": [
            {
              "name": "Get My Profile",
              "request": {
                "method": "GET",
                "url": "{{quick-hire-url}}/users/profile/me",
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    { "key": "token", "value": "{{quick-hire-usertoken}}", "type": "string" }
                  ]
                }
              }
            },
            {
              "name": "Update Profile (Form-Data)",
              "request": {
                "method": "PATCH",
                "url": "{{quick-hire-url}}/users/profile/me",
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    { "key": "token", "value": "{{quick-hire-usertoken}}", "type": "string" }
                  ]
                },
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    { "key": "fullName", "value": "John Updated", "type": "text" },
                    { "key": "bio", "value": "Expert Nodejs Dev", "type": "text" },
                    { "key": "profileImage", "type": "file", "src": [] }
                  ]
                }
              }
            }
          ]
        },
        {
          "name": "Jobs & Applications",
          "item": [
            {
              "name": "Apply for Job (Form-Data)",
              "request": {
                "method": "POST",
                "url": "{{quick-hire-url}}/applications/job/:jobId",
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    { "key": "token", "value": "{{quick-hire-usertoken}}", "type": "string" }
                  ]
                },
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    { "key": "coverLetter", "value": "I am interested", "type": "text" },
                    { "key": "resume", "type": "file", "src": [] }
                  ]
                }
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Company (Employer)",
      "item": [
        {
          "name": "Auth",
          "item": [
            {
              "name": "Unified Register (With Company)",
              "request": {
                "method": "POST",
                "url": "{{quick-hire-url}}/auth/register",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"fullName\": \"Employer One\",\n  \"email\": \"recruiter@company.com\",\n  \"password\": \"Company123!\",\n  \"role\": \"COMPANY\",\n  \"companyName\": \"SparkTech\",\n  \"companyIndustry\": \"IT\"\n}"
                }
              }
            },
            {
              "name": "Login Company",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const resp = pm.response.json(); if(resp.success) pm.environment.set('quick-hire-companytoken', resp.data.accessToken);"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "url": "{{quick-hire-url}}/auth/login",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"recruiter@company.com\",\n  \"password\": \"Company123!\"\n}"
                }
              }
            }
          ]
        },
        {
          "name": "Jobs",
          "item": [
            {
              "name": "Post Job (Direct)",
              "request": {
                "method": "POST",
                "url": "{{quick-hire-url}}/jobs",
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    { "key": "token", "value": "{{quick-hire-companytoken}}", "type": "string" }
                  ]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"Nodejs Dev\",\n  \"description\": \"Expert required\",\n  \"location\": \"Dhaka\",\n  \"salaryRange\": \"$2k-$4k\",\n  \"type\": \"FULL_TIME\"\n}"
                }
              }
            }
          ]
        },
        {
          "name": "Profile",
          "item": [
            {
              "name": "Create Company Profile (Form-Data)",
              "request": {
                "method": "POST",
                "url": "{{quick-hire-url}}/companies",
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    { "key": "token", "value": "{{quick-hire-admintoken}}", "type": "string" }
                  ]
                },
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    { "key": "name", "value": "SparkTech Ltd", "type": "text" },
                    { "key": "location", "value": "Dhaka", "type": "text" },
                    { "key": "logo", "type": "file", "src": [] }
                  ]
                }
              }
            },
            {
              "name": "Update Company Details (Form-Data)",
              "request": {
                "method": "PATCH",
                "url": "{{quick-hire-url}}/companies/:id",
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    { "key": "token", "value": "{{quick-hire-companytoken}}", "type": "string" }
                  ]
                },
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    { "key": "description", "value": "Leading Tech Agency", "type": "text" },
                    { "key": "logo", "type": "file", "src": [] }
                  ]
                }
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    { "key": "quick-hire-url", "value": "http://localhost:5000/api/v1", "type": "string" }
  ]
}
