{
  "info": {
    "_postman_id": "quick-hire-ultimate-v2",
    "name": "QuickHire Ultimate API Collection",
    "description": "100% Exhaustive collection for Admin, Company, and User. Features Unified Registration, Auto-Activation, and Interview Scheduling.",
