              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "User (Job Seeker)",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{quick-hire-usertoken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user/me",
              "host": ["{{baseUrl}}"],
              "path": ["user", "me"]
            }
          }
        },
        {
          "name": "Get Jobs (Public/Approved)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/job",
              "host": ["{{baseUrl}}"],
              "path": ["job"],
              "query": [
                { "key": "search", "value": "developer", "disabled": true },
                { "key": "page", "value": "1", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Apply for Job",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{quick-hire-usertoken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"resumeUrl\": \"https://dropbox.com/my-resume.pdf\",\n    \"coverLetter\": \"I am excited about this role...\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/application/:jobId",
              "host": ["{{baseUrl}}"],
              "path": ["application", ":jobId"],
              "variable": [{ "key": "jobId", "value": "" }]
            }
          }
        },
        {
          "name": "Toggle Save Job",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{quick-hire-usertoken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/saved-job/:jobId",
              "host": ["{{baseUrl}}"],
              "path": ["saved-job", ":jobId"],
              "variable": [{ "key": "jobId", "value": "" }]
            }
          }
        }
      ]
    },
    {
      "name": "Company",
      "item": [
        {
          "name": "Create Company Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{quick-hire-usertoken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Spark Tech\",\n    \"location\": \"Dhaka, Bangladesh\",\n    \"industry\": \"Software Engineering\",\n    \"website\": \"https://sparktech.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/company",
              "host": ["{{baseUrl}}"],
              "path": ["company"]
            }
          }
        },
        {
          "name": "Post a Job",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{quick-hire-companytoken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Senior Node.js Developer\",\n    \"description\": \"Join our team to build scalable backends...\",\n    \"requirements\": \"5+ years experience, Prisma, Redis\",\n    \"salaryRange\": \"$2000 - $4000\",\n    \"location\": \"Remote\",\n    \"type\": \"FULL_TIME\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/job",
              "host": ["{{baseUrl}}"],
              "path": ["job"]
            }
          }
        },
        {
          "name": "Get Applications for a Job",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{quick-hire-companytoken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/application/:jobId",
              "host": ["{{baseUrl}}"],
              "path": ["application", ":jobId"],
              "variable": [{ "key": "jobId", "value": "" }]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get Pending Jobs",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{quick-hire-admintoken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/job/admin?status=PENDING",
              "host": ["{{baseUrl}}"],
              "path": ["job", "admin"],
              "query": [{ "key": "status", "value": "PENDING" }]
            }
          }
        },
        {
          "name": "Approve Job",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{quick-hire-admintoken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"APPROVED\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/job/status/:jobId",
              "host": ["{{baseUrl}}"],
              "path": ["job", "status", ":jobId"],
              "variable": [{ "key": "jobId", "value": "" }]
            }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{quick-hire-admintoken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user",
              "host": ["{{baseUrl}}"],
              "path": ["user"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1",
      "type": "string"
