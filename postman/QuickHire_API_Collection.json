  "item": [
    {
      "name": "Admin",
      "item": [
        {
          "name": "Auth",
          "item": [
            {
              "name": "Login",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const response = pm.response.json();",
                      "if (response.success) {",
                      "    pm.environment.set(\"quick-hire-admintoken\", response.data.accessToken);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\n    \"email\": \"admin@quickhire.com\",\n    \"password\": \"Admin123!\"\n}"
                },
                "url": "{{baseUrl}}/auth/login"
              }
            },
            {
              "name": "Logout",
              "request": {
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    {
                      "key": "token",
                      "value": "{{quick-hire-admintoken}}",
                      "type": "string"
                    }
                  ]
                },
                "method": "POST",
                "header": [],
                "url": "{{baseUrl}}/auth/logout"
              }
            }
          ]
        },
        {
