model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String?  // URL or identifier for frontend icon
  
  // Relationships
  jobs      Job[]    @relation("CategoryJobs")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)

  @@map("categories")
}
