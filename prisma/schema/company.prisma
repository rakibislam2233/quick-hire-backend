model Company {
  id           String  @id @default(cuid())
  name         String
  description  String?
  website      String?
  logo         String?
  location     String?
  industry     String?
  contactEmail String?
  contactPhone String?
  isVerified   Boolean @default(false)
  ownerId      String?

  // Frontend compatibility fields
  founded       String?
  employeeSize  String? @map("employeeCount")
  openPositions Int     @default(0)

  // Relationships
  owner     User?    @relation("CompanyOwner", fields: [ownerId], references: [id])
  employees User[]
  jobs      Job[]    @relation("CompanyJobs")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)
  userId    String?

  @@map("companies")
}
