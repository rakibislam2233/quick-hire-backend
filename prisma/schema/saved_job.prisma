model SavedJob {
  id    String @id @default(cuid())
  jobId String
  job   Job    @relation("JobSavedBy", fields: [jobId], references: [id])
  userId String
  user   User   @relation("UserSavedJobs", fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([jobId, userId])
  @@map("saved_jobs")
}
